{
    "version": "2.0.0",
    "tasks": [
        {
            "label": "ESP-IDF: Build",
            "type": "shell",
            "command": ". 'C:\\Espressif\\tools\\Microsoft.v6.0.1.PowerShell_profile.ps1'; Set-Location '${workspaceFolder}'; idf.py build; if ($LASTEXITCODE -ne 0) { exit $LASTEXITCODE }",
            "options": {
                "shell": {
                    "executable": "pwsh.exe",
                    "args": ["-NoLogo", "-NoProfile", "-ExecutionPolicy", "Bypass", "-Command"]
                }
            },
            "group": {
                "kind": "build",
                "isDefault": true
            },
            "presentation": {
                "reveal": "always",
                "panel": "shared"
            },
            "problemMatcher": []
        },
        {
            "label": "Web Server: Start",
            "type": "shell",
            "command": "cd frixos-web-server && .\\venv\\Scripts\\activate && uvicorn app.main:app --host 0.0.0.0 --port 8080 --reload",
            "group": {
                "kind": "build",
                "isDefault": false
            },
            "presentation": {
                "reveal": "always",
                "panel": "new"
            },
            "problemMatcher": []
        }
    ]
}
