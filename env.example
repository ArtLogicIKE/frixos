# Copy this file to .env and fill in your values.
# The .env file is gitignored and will not be published.

# OpenWeatherMap API key (legacy; kept for the dormant wifi_get_openweather path).
# Met.no Locationforecast does not require an API key, so this can be left blank.
WEATHER_API_KEY=

# Met.no requires a unique, identifying User-Agent on every request (no API key).
# Use something like "Frixos/1.0 https://github.com/artlogicike/frixos" or include
# your contact email. Generic UAs (okhttp, Java, Dalvik...) are rejected with 403.
WEATHER_USER_AGENT=Frixos/1.0 github.com/artlogicike/frixos

# Manufacturer fallback network (optional). If stored WiFi credentials fail, the device
# will try this network before starting the provisioning portal. Leave empty to skip.
ARTLOGIC_SSID=
ARTLOGIC_PASSWORD=
